# local_agent.py environment configuration
# Copy this file to .env and fill in real values

# Railway PostgreSQL connection string (get from Railway dashboard)
DATABASE_URL=postgresql://postgres:PASSWORD@mainline.proxy.rlwy.net:PORT/railway

# AdsPower local API (default is fine if running on same machine)
ADSPOWER_URL=http://localhost:50325

# Poll interval in seconds (default: 2)
POLL_INTERVAL=2
